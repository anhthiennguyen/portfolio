{
  "rewrites": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "dj.anhthien.site" }],
      "destination": "/dj/index.html"
    },
    {
      "source": "/",
      "has": [{ "type": "host", "value": "dev.anhthien.site" }],
      "destination": "/dev/index.html"
    }
  ],
  "redirects": [
    {
      "source": "/blog",
      "destination": "https://blog.anhthien.site",
      "permanent": false
    },
    {
      "source": "/blog/:path*",
      "destination": "https://blog.anhthien.site/:path*",
      "permanent": false
    }
  ]
}
